@page
@model PortalAcademico.Web.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="row justify-content-center align-items-center mt-5 mb-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden course-card">
            <div class="card-header bg-primary text-white text-center p-5 border-0">
                <i class="bi bi-person-circle display-1 mb-3"></i>
                <h3 class="fw-bold mb-0">Bienvenido al Portal</h3>
                <p class="mb-0 opacity-75 mt-2">Ingresa tus credenciales para continuar</p>
            </div>
            <div class="card-body p-5 bg-white">
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 rounded-3 mb-4" role="alert"></div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control form-control-modern border-0 bg-light" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="text-muted"><i class="bi bi-envelope-fill me-2 text-primary"></i>Correo Electrónico</label>
                        <span asp-validation-for="Input.Email" class="text-danger small fw-bold"></span>
                    </div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Input.Password" class="form-control form-control-modern border-0 bg-light" autocomplete="current-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password" class="text-muted"><i class="bi bi-lock-fill me-2 text-primary"></i>Contraseña</label>
                        <span asp-validation-for="Input.Password" class="text-danger small fw-bold"></span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="Input.RememberMe" />
                            <label class="form-check-label text-muted fw-medium ms-1" asp-for="Input.RememberMe">
                                Recordar mi sesión
                            </label>
                        </div>
                    </div>
                    
                    <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-modern btn-lg fw-bold mb-2 shadow">
                        Ingresar de Forma Segura <i class="bi bi-box-arrow-in-right ms-2"></i>
                    </button>
                </form>
            </div>
        </div>
        
        <div class="text-center mt-4">
            <p class="text-muted small">
                ¿No tienes cuenta? Los registros están deshabilitados durante el examen. <br/>
                Inicia sesión como <strong>coordinador@portal.edu</strong> (Clave: <strong>Admin123!</strong>)
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
