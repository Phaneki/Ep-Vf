<!DOCTYPE html>
<html lang="es">
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portal Académico</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PortalAcademico.Web.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light navbar-glass fixed-top">
            <div class="container">
                <a class="navbar-brand fw-bold text-gradient-primary fs-4" asp-area="" asp-controller="Cursos" asp-action="Index">
                    <i class="bi bi-mortarboard-fill me-2"></i>Portal Académico
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium" asp-area="" asp-controller="Cursos" asp-action="Index">
                                <i class="bi bi-journal-text me-1"></i> Catálogo
                            </a>
                        </li>
                        @if (User.IsInRole("Coordinador"))
                        {
                            <li class="nav-item ms-lg-2">
                                <a class="nav-link text-danger fw-bold" asp-area="" asp-controller="Coordinador" asp-action="Index">
                                    <i class="bi bi-shield-lock-fill me-1"></i> Panel Coordinador
                                </a>
                            </li>
                        }
                        @{
                            var lastCourseId = HttpContextAccessor.HttpContext?.Session.GetString("UltimoCursoId");
                            var lastCourseName = HttpContextAccessor.HttpContext?.Session.GetString("UltimoCursoNombre");
                            if (!string.IsNullOrEmpty(lastCourseId) && !string.IsNullOrEmpty(lastCourseName))
                            {
                                <li class="nav-item ms-auto">
                                    <a class="nav-link text-white bg-primary rounded px-3 fw-bold shadow-sm btn-modern" asp-controller="Cursos" asp-action="Details" asp-route-id="@lastCourseId">
                                        <i class="bi bi-arrow-return-left me-1"></i> Volver a @lastCourseName
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container" style="margin-top: 90px; flex: 1;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-premium mt-auto">
        <div class="container text-center">
            &copy; 2026 - Portal Académico Universitario - Desarrollado para Examen Parcial
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
